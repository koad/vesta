#!/usr/bin/env bash
# status — Vesta platform status digest
# Shows: git state, open issues (all monitored repos), active projects

ENTITY_DIR="/home/koad/.vesta"
REPOS=("koad/vesta" "koad/juno" "koad/vulcan")

echo "=== Vesta Status ==="
echo "Date: $(date '+%Y-%m-%d %H:%M')"
echo ""

# --- Git state ---
echo "--- Repo ---"
cd "$ENTITY_DIR" || exit 1
git_status=$(git status --short 2>/dev/null)
git_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
git_ahead=$(git log origin/"$git_branch".."$git_branch" --oneline 2>/dev/null | wc -l | tr -d ' ')

echo "Branch: $git_branch"
if [ "$git_ahead" -gt 0 ]; then
  echo "Unpushed commits: $git_ahead"
fi
if [ -n "$git_status" ]; then
  echo "Uncommitted changes:"
  echo "$git_status" | sed 's/^/  /'
else
  echo "Working tree: clean"
fi
echo ""

# --- Active projects ---
echo "--- Projects ---"
if [ -d "$ENTITY_DIR/projects" ]; then
  find "$ENTITY_DIR/projects" -name "project.md" | sort | while read -r f; do
    status=$(grep -m1 '^status:' "$f" 2>/dev/null | awk '{print $2}')
    title=$(grep -m1 '^title:' "$f" 2>/dev/null | sed 's/title: *//' | tr -d '"')
    if [ "$status" = "active" ] || [ "$status" = "blocked" ]; then
      echo "  [$status] $title"
    fi
  done
else
  echo "  (no projects directory)"
fi
echo ""

# --- GitHub issues ---
echo "--- GitHub Issues ---"
for repo in "${REPOS[@]}"; do
  issues=$(gh issue list --repo "$repo" 2>/dev/null | while IFS=$'\t' read -r num state title rest; do
    echo "  ${repo}#${num} ${title}"
  done)
  echo "${repo}:"
  echo "${issues:-  (none)}"
done
