#!/usr/bin/env bash
# audit-issues — triage open GitHub issues for protocol relevance
# Fetches issues from all monitored entity repos and flags protocol-level issues
# Usage: vesta audit-issues [--add-to-project]

set -e

REPOS=("koad/vesta" "koad/juno" "koad/vulcan")
PROJECT_ID=5  # koad:io Protocol project
ADD_TO_PROJECT=false
PROTOCOL_PATHS=("\.koad-io/" "entity.*structure" "trust.*bond" "commands" "spawn.*protocol" "gestation" "cascade.*environment" "inter-entity" "daemon" "package.*system")

# Parse flags
for arg in "$@"; do
  case "$arg" in
    --add-to-project) ADD_TO_PROJECT=true ;;
  esac
done

# Color codes for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

echo "=== Protocol Issue Audit ==="
echo "Scanning: ${REPOS[*]}"
echo ""

flagged_issues=()

# Helper: check if issue touches protocol-relevant paths or concepts
check_protocol_signal() {
  local issue_title="$1"
  local issue_body="$2"
  local combined="${issue_title} ${issue_body}"

  # Check for direct path mentions
  for path in "${PROTOCOL_PATHS[@]}"; do
    if [[ "$combined" =~ $path ]]; then
      return 0  # True - found protocol signal
    fi
  done

  # Check for format/convention/sequence language (protocol indicator)
  if [[ "$combined" =~ (canonical|format|convention|sequence|spec|standard|protocol|schema|structure|model) ]]; then
    # Cross-check: is it proposing something new or asking for clarification?
    if [[ "$combined" =~ (create|define|proposal|need|missing|lack|gap|how.*should|standardize) ]]; then
      return 0
    fi
  fi

  return 1  # False - no protocol signal
}

# Fetch and analyze issues from each repo
for repo in "${REPOS[@]}"; do
  echo -e "${GREEN}${repo}${NC}"

  # Fetch issues in table format (simpler parsing)
  issues_output=$(gh issue list --repo "$repo" --state open 2>/dev/null)

  if [ -z "$issues_output" ]; then
    echo "  (no open issues)"
    continue
  fi

  # Parse table output
  while IFS=$'\t' read -r num state title rest; do
    [ -z "$num" ] && continue
    [ "$num" = "NUMBER" ] && continue  # Skip header

    # Fetch full issue body for protocol signal check
    body=$(gh issue view "$num" --repo "$repo" --json body -q '.body' 2>/dev/null || echo "")

    if check_protocol_signal "$title" "$body"; then
      echo -e "  ${YELLOW}#${num}${NC} ${title}"

      # Extract first 80 chars of body as context
      if [ -n "$body" ]; then
        reason=$(echo "$body" | head -1 | cut -c1-80)
        echo "    → ${reason}"
        [ ${#reason} -eq 80 ] && echo "    ..."
      fi

      flagged_issues+=("${repo}#${num}")
    fi
  done <<< "$issues_output"
done

echo ""
echo "=== Summary ==="
echo "Flagged for protocol review: ${#flagged_issues[@]}"

if [ ${#flagged_issues[@]} -gt 0 ]; then
  echo ""
  echo "Flagged issues:"
  for issue in "${flagged_issues[@]}"; do
    echo "  $issue"
  done

  if [ "$ADD_TO_PROJECT" = true ]; then
    echo ""
    echo "Adding to GitHub Project #$PROJECT_ID with stage: Gap"
    for issue in "${flagged_issues[@]}"; do
      # Parse repo and issue number
      IFS='#' read -r repo_name issue_num <<< "$issue"
      echo "  Adding ${repo_name}#${issue_num}..."
      gh issue edit "$issue_num" --repo "$repo_name" --add-project "koad:io Protocol" --add-project-field stage --set-project-field-value "Gap" 2>/dev/null || echo "    (skipped - may already be in project)"
    done
  else
    echo ""
    echo "Tip: Run with --add-to-project to automatically add flagged issues to the Protocol Project"
  fi
fi
