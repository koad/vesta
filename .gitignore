# Runtime artifacts (regenerate on their own)
.local/
node_modules/
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.tmp/
dist/

# Entity GPG keyring — private keys, never commit
keyring/

# Flight plans — ephemeral dispatch artifacts (durable record is commit trailer)
flight-plans/

# Claude Code harness artifacts (regenerated per session)
.claude.json
.claude/
mcp-needs-auth-cache.json

# Runtime state
var/

# Python bytecode
__pycache__/
*.pyc
*.pyo

# .io files — signed visual artifacts (VESTA-SPEC-136)
# These are PNGs with embedded signed payloads; not part of the public storefront.
*.io
